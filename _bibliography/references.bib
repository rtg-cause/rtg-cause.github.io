@inproceedings{DD:MBMV26,
 author     = {Caroline Dominik and Rolf Drechsler},
 title      = {Using Virtual Prototypes for Causal Fault Explanation at System Level},
 booktitle  = {Methoden und Beschreibungssprachen zur Modellierung und Verifikation von Schaltungen und Systemen (MBMV)},
 year       = {2026},
 publisher  = {IEEE},
 abstract   = {With Virtual Prototypes (VPs), it is possible to significantly improve the debugging process during system design as the interaction of components can be analyzed and internal variable values can be accessed. But in case of detecting a fault, it remains challenging to determine its specific cause, as the load of available information can be overwhelming. To address this issue, we propose to monitor a VP at runtime to extract an under-approximating formal model of the system behavior, and derive causal explanations by model checking. For this, we determine the sufficient condition of a failure based on the order and context of events. This is demonstrated using an abstracted controller for a wind turbine, implemented using a RISC-V VP.}
}

